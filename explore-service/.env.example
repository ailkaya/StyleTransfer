# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/style_transfer_explore
SYNC_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/style_transfer_explore

# File storage
UPLOAD_DIR=./explore_uploads
MAX_UPLOAD_SIZE_MB=500

# CORS
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Security
SECRET_KEY=change-me-in-production-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Logging
LOG_LEVEL=INFO
