# ==========================================
# 个性化文本风格迁移系统 - 环境变量配置示例
# ==========================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ==========================================

# ------------------------------------------
# 应用配置
# ------------------------------------------
# 应用名称
APP_NAME=Style Transfer API

# 应用版本
APP_VERSION=0.1.0

# 调试模式 (true/false)
DEBUG=false

# ------------------------------------------
# 数据库配置 (PostgreSQL)
# ------------------------------------------
# 异步数据库URL (用于主应用)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/style_transfer

# 同步数据库URL (用于Celery任务)
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/style_transfer

# 数据库主机 (可选，用于Docker环境)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=style_transfer
# DB_USER=postgres
# DB_PASSWORD=postgres

# ------------------------------------------
# Redis 配置
# ------------------------------------------
# Redis URL (用于Celery和缓存)
REDIS_URL=redis://localhost:6379/0

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Redis 主机和端口 (可选)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# ------------------------------------------
# 大模型 API 配置 (OpenAI 格式)
# ------------------------------------------
# API 基础 URL
# 示例：OpenAI官方: https://api.openai.com/v1
# 示例：本地vLLM: http://localhost:8000/v1
# 示例：Azure OpenAI: https://your-resource.openai.azure.com/openai/deployments/your-deployment
LLM_BASE_URL=https://api.openai.com/v1

# 模型名称
LLM_MODEL_NAME=gpt-3.5-turbo

# API 密钥
# 从相应服务商获取
LLM_API_KEY=sk-your-api-key-here

# 请求超时时间 (秒)
LLM_TIMEOUT=30

# ------------------------------------------
# 文件存储配置
# ------------------------------------------
# 上传文件存储路径
UPLOAD_DIR=./uploads

# 模型文件存储路径
MODELS_DIR=./models

# 最大上传文件大小 (MB)
MAX_UPLOAD_SIZE=10

# ------------------------------------------
# CORS 配置
# ------------------------------------------
# 允许的源 (逗号分隔，*表示允许所有)
CORS_ORIGINS=*

# ------------------------------------------
# 安全配置 (生产环境必需)
# ------------------------------------------
# 密钥 (用于加密，生产环境必须修改)
SECRET_KEY=your-secret-key-change-this-in-production

# 访问令牌过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------------------------------
# 日志配置
# ------------------------------------------
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径 (可选)
# LOG_FILE=./logs/app.log

# 是否通过api代替本地模型生成
GENERATING_MOCK_MODE=true

# ------------------------------------------
# 评估配置
# ------------------------------------------
# 评估时生成的测试样本数量
EVALUATION_SAMPLE_COUNT=5

# Mock评估数据时的延迟时间（秒），用于模拟真实评估耗时
EVALUATION_MOCK_DELAY=20

# 是否使用固定数据代替评估数据
EVALUATION_MOCK_MODE=true

# 是否将comment应用于下次微调
APPLY_COMMENT_ADJUSTMENT=false

# ------------------------------------------
# 训练配置
# ------------------------------------------
# 训练Mock模式 (true=模拟训练, false=真实QLoRA训练)
TRAINING_MOCK_MODE=true

# 本地基础模型名称由 style.base_model 提供，不再通过环境变量配置